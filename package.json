{
  "name": "mercurio",
  "private": true,
  "type": "module",
  "description": "Peer-to-peer logistics network with non-custodial Lightning payments",
  "license": "MIT",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:integration": "pnpm --filter @mercurio/escrow test:integration && pnpm --filter @mercurio/api test:integration",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @mercurio/db db:generate",
    "db:migrate": "pnpm --filter @mercurio/db db:migrate",
    "db:seed": "pnpm --filter @mercurio/db db:seed",
    "setup": "pnpm db:migrate && pnpm db:seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.1"
  }
}
