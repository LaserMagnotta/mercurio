# Mercurio — production environment (ADR-024 §5). Copy to `.env` NEXT TO THIS
# FILE, fill in real values, and keep it off the repo (.gitignore covers it):
#
#   cp infra/production/.env.example infra/production/.env
#   chmod 600 infra/production/.env
#
# Every value below is a PLACEHOLDER. Generate real secrets on the host, never
# reuse an example. Full reference: docs/DEPLOY.md

# --- Public origin -----------------------------------------------------------
# The domain Caddy serves and obtains a certificate for. Its DNS A/AAAA record
# must already point at this host. Use `http://localhost` for a local test run
# (plain HTTP, no ACME).
MERCURIO_DOMAIN=mercurio.example

# Absolute base URL used to build the links inside emails (magic link,
# tracking, pickup). Same origin as above, with the scheme.
WEB_URL=https://mercurio.example

# --- Database ----------------------------------------------------------------
# Keep the password URL-safe: compose puts it into a postgres:// URL, so `@`,
# `:`, `/` and `#` would break it. `openssl rand -hex 32` is always safe.
POSTGRES_USER=mercurio
POSTGRES_PASSWORD=replace-me-with-openssl-rand-hex-32
POSTGRES_DB=mercurio

# --- Escrow coordinator ------------------------------------------------------
# 32 random bytes, hex: `openssl rand -hex 32`.
#
# THIS KEY IS NOT ROTATABLE IN PLACE AND MUST BE BACKED UP. It encrypts the
# payment preimages and the users' wallet secrets at rest (ADR-013). Change it
# or lose it and every sealed wallet stops opening: pending holds can no
# longer be released, and they resolve by expiring back to their payers.
COORDINATOR_KEY=replace-me-with-openssl-rand-hex-32

# --- SMTP --------------------------------------------------------------------
# A real relay: email is how sign-in and every lifecycle notification reaches
# users. SMTP_FROM must be a domain you control (SPF/DKIM) or mail is spam.
# Port 587 (STARTTLS) or 465 (implicit TLS) — TLS is inferred from the port.
SMTP_HOST=smtp.relay.example
SMTP_PORT=587
SMTP_USER=postmaster@mercurio.example
SMTP_PASS=replace-me-with-the-relay-password
SMTP_FROM=Mercurio <no-reply@mercurio.example>

# --- Optional ----------------------------------------------------------------
# EUR→sats snapshot rate (ADR-008). Default 1600 if unset.
#EUR_RATE_SATS_PER_EUR=1600

# Photo blob storage (ADR-020/ADR-023). The default `fs` driver is right for
# this single-replica deployment and stores blobs on the `photos` volume;
# leave these commented unless you are moving to an object store.
#PHOTO_STORAGE_DRIVER=s3
#PHOTO_STORAGE_S3_ENDPOINT=https://s3.example
#PHOTO_STORAGE_S3_BUCKET=mercurio-photos
#PHOTO_STORAGE_S3_ACCESS_KEY_ID=replace-me
#PHOTO_STORAGE_S3_SECRET_ACCESS_KEY=replace-me

# NEVER set FAKE_WALLETS here: it backs wallets with an in-memory fake
# Lightning network. The API refuses to start if it is true in production.
